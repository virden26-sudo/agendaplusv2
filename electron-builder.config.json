{
    "appId": "com.yourdoamnin.yourapp",
    "directories": {
        "buildResources": "resources"
    },
    "files": [
        "assets/**/*",
        "out/**/*",
        "main.js",
        "bridge.js",
        "package.json",
        "node_modules/**/*"
    ],
    "nsis": {
        "allowElevation": true,
        "oneClick": false,
        "allowToChangeInstallationDirectory": true
    },
    "win": {
        "target": "nsis",
        "icon": "assets/appIcon.ico"
    },
    "mac": {
        "category": "your.app.category.type",
        "target": "dmg"
    }
}