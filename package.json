{
  "name": "agenda-plus",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/start-dev-services.js",
    "dev:next": "next dev -p 3000 --webpack",
    "build": "next build --webpack",
    "export": "next build && next export",
    "start": "npm --prefix electron run electron:start",
    "RunIt": "next start -p 3000",
    "electron:start-live": "npm --prefix electron run electron:start-live",
    "electron:sync": "npm run build && node scripts/fix-electron-rsc-paths.js && npx cap sync @capacitor-community/electron && node scripts/fix-electron-rsc-paths.js",
    "electron:build": "npm run electron:sync && npm --prefix electron run electron:make",
    "electron:pack": "npm run electron:sync && npm --prefix electron run electron:pack",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "prod:build": "npm run build",
    "prod:serve": "npx serve out -p 3000",
    "test:prod": "npx playwright test",
    "ai": "genkit start -- tsx --watch src/ai/dev.ts",
    "cap:sync": "npx cap sync",
    "android:sync": "npm run build && npx cap sync android",
    "android:apk": "npm run android:sync && cd android && gradlew.bat assembleRelease",
    "android:install": "adb install -r android\\app\\build\\outputs\\apk\\release\\app-release.apk"
  },
  "dependencies": {
    "@capacitor-community/electron": "^5.0.1",
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^7.6.2",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.3.1",
    "@genkit-ai/next": "^1.16.1",
    "@hookform/resolvers": "^4.1.3",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "chromium-bidi": "^15.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "dotenv": "^16.5.0",
    "embla-carousel-react": "^8.6.0",
    "firebase": "^11.9.1",
    "genkit": "^1.16.1",
    "genkitx-ollama": "^1.16.1",
    "ics": "^3.7.2",
    "lucide-react": "^0.475.0",
    "next": "^16.2.5",
    "patch-package": "^8.0.0",
    "puppeteer-core": "^24.42.0",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-markdown": "^10.1.0",
    "recharts": "^2.15.1",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7",
    "turbopack": "^0.0.1",
    "uuid": "^9.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@cspell/cspell-bundled-dicts": "^10.0.1",
    "@eslint/eslintrc": "^3.3.5",
    "@opentelemetry/exporter-jaeger": "^2.7.0",
    "@playwright/test": "^1.40.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/uuid": "^9.0.8",
    "@types/webpack": "^5.28.5",
    "concurrently": "^9.2.1",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.4",
    "genkit-cli": "^0.0.2",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "webpack": "^5.106.2"
  },
  "allowScripts": {
    "@firebase/util@1.12.1": true,
    "protobufjs@7.5.5": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.11.1": true
  }
}
